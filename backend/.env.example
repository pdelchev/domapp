# DomApp backend environment variables.
# Copy to `.env` and fill in real values for production deployments.
# Local dev works without any of these (uses SQLite + filesystem storage).

# --- Django ---
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Cloudflare R2 (object storage for uploaded files) ---
# Leave empty to use local filesystem storage (default for dev).
# When all four R2_* vars below are set, all FileField/ImageField uploads
# (supplement photos, blood test PDFs, document vault, vehicle files, etc.)
# automatically write to R2.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# Optional: public URL for the bucket (custom domain or pub-*.r2.dev).
# When set, files are served as un-signed public URLs instead of signed S3 URLs.
R2_PUBLIC_URL=

# --- WHOOP OAuth2 ---
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3000/health/recovery/callback
